# Path to Claude Code CLI executable
# On Windows it might be "claude.exe" or a full path like "C:\\Users\\User\\AppData\\Local\\bin\\claude.exe"
CLAUDE_CODE_COMMAND=claude

# Timeout for PPT generation in seconds (default: 600 = 10 minutes)
CLAUDE_TIMEOUT=600

# LLM model ("" = use Claude Code default). Options: deepseek-v4-pro, deepseek-v4-flash
CLAUDE_MODEL=deepseek-v4-pro

# Backend server port
BACKEND_PORT=8000
