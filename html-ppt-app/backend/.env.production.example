# ── Phase 5B: Railway Production Environment Variables ───────────────
# Copy this file to .env and fill in real values.
# In Railway: set these as service variables (or shared variables).

# ── Database ─────────────────────────────────────────────────────────
# Railway PostgreSQL plugin provides DATABASE_URL automatically.
# For local dev with SQLite: DATABASE_URL=sqlite:///./app.db
DATABASE_URL=postgresql://...

# ── Redis ────────────────────────────────────────────────────────────
# Railway Redis plugin provides REDIS_URL automatically.
REDIS_URL=redis://localhost:6379/0

# ── Auth (Phase 4G) ──────────────────────────────────────────────────
# CHANGE THESE in production!
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
JWT_EXPIRE_DAYS=7
ADMIN_PASSWORD=change-me

# ── Claude Code ──────────────────────────────────────────────────────
CLAUDE_CODE_COMMAND=claude
CLAUDE_TIMEOUT=1800

# ── Anthropic API Key (REQUIRED for Claude Code) ─────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Worker ───────────────────────────────────────────────────────────
WORKER_COUNT=2

# ── Rate Limiting ────────────────────────────────────────────────────
FREE_GENERATIONS_PER_MONTH=3

# ── Storage (Phase 5B) ───────────────────────────────────────────────
STORAGE_PROVIDER=s3
# Cloudflare R2 or any S3-compatible storage
S3_BUCKET=slidehttp-outputs
S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=xxx
S3_SECRET_ACCESS_KEY=xxx
S3_REGION=auto
S3_PUBLIC_BASE_URL=https://pub-<hash>.r2.dev

# ── URLs (for CORS and generated links) ──────────────────────────────
PUBLIC_BACKEND_URL=https://your-backend.railway.app
FRONTEND_URL=https://your-frontend.vercel.app
CORS_ORIGINS=https://your-frontend.vercel.app,http://localhost:5173
