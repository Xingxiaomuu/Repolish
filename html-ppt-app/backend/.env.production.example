# ── Phase 5A: Railway Production Environment Variables ───────────────
# Copy this file to .env and fill in real values.
# In Railway: set these as service variables (or shared variables).

# ── Database ─────────────────────────────────────────────────────────
# SQLite on a Railway volume. The volume should be mounted at /data.
DATABASE_URL=sqlite:////data/app.db

# ── Redis ────────────────────────────────────────────────────────────
# Railway Redis plugin will provide REDIS_URL automatically.
# If using external Redis, set it here.
REDIS_URL=redis://localhost:6379/0

# ── Auth (Phase 4G) ──────────────────────────────────────────────────
# CHANGE THESE in production!
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
JWT_EXPIRE_DAYS=7
ADMIN_PASSWORD=change-me

# ── Claude Code ──────────────────────────────────────────────────────
# The CLI command — "claude" should be on PATH from npm install -g
CLAUDE_CODE_COMMAND=claude
CLAUDE_TIMEOUT=1800

# ── Anthropic API Key (REQUIRED for Claude Code) ─────────────────────
# Claude Code CLI needs this to call the Anthropic API.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Worker ───────────────────────────────────────────────────────────
WORKER_COUNT=2

# ── Rate Limiting ────────────────────────────────────────────────────
FREE_GENERATIONS_PER_MONTH=3

# ── Output ───────────────────────────────────────────────────────────
# Where job outputs (index.html, standalone.html, zip, logs) are stored.
# Must be on a persistent volume!
OUTPUT_DIR=/data/outputs

# ── URLs (for CORS and generated links) ──────────────────────────────
# The public URL of your backend API on Railway
PUBLIC_BACKEND_URL=https://your-app.railway.app

# The public URL of your frontend (if deployed separately)
FRONTEND_URL=https://your-frontend.vercel.app

# CORS allowed origins — comma-separated
CORS_ORIGINS=https://your-frontend.vercel.app,http://localhost:5173

# ── Optional: Sentry / Logging ───────────────────────────────────────
# SENTRY_DSN=
# LOG_LEVEL=INFO
