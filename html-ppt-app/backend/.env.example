# ── Server ───────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=5173

# ── Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Database ─────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./app.db

# ── Claude Code ──────────────────────────────────────────────────────
CLAUDE_CODE_COMMAND=claude
# Timeout in seconds (max 30 min for Claude Code generation)
CLAUDE_TIMEOUT=1800

# ── Worker ───────────────────────────────────────────────────────────
WORKER_COUNT=2

# ── Admin ────────────────────────────────────────────────────────────
# Set a password to protect admin page. Leave empty = no protection.
ADMIN_PASSWORD=change-me

# ── Rate Limiting ────────────────────────────────────────────────────
# Free generations per email per month
FREE_GENERATIONS_PER_MONTH=3

# ── Auth (Phase 4G) ──────────────────────────────────────────────────
JWT_SECRET=change-me
JWT_EXPIRE_DAYS=7

# ── Phase 5D: Invite Code ──────────────────────────────────────────────
# Set to true to require invite code for registration
INVITE_CODE_REQUIRED=false
# Universal test invite code (empty = disabled). Accepts any number of uses.
TEST_INVITE_CODE=

# ── Phase 5D: Input Size Limits ─────────────────────────────────────────
MAX_REPORT_CHARS=80000
MAX_TOPIC_CHARS=200
MAX_EXTRA_REQUIREMENTS_CHARS=2000

# ── Phase 5D: Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_REGISTER_PER_HOUR=10
RATE_LIMIT_LOGIN_PER_10MIN=20
RATE_LIMIT_CREATE_JOB_PER_HOUR=5

# ── Storage (Phase 5B) ──────────────────────────────────────────────
# "local" = filesystem (dev), "s3" = S3-compatible object storage (production)
STORAGE_PROVIDER=local
# S3 / Cloudflare R2 (only needed when STORAGE_PROVIDER=s3)
# S3_BUCKET=your-bucket
# S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# S3_ACCESS_KEY_ID=xxx
# S3_SECRET_ACCESS_KEY=xxx
# S3_REGION=auto
# S3_PUBLIC_BASE_URL=https://pub-<hash>.r2.dev
